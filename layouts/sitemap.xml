{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range .Data.Pages }}
  {{- if not .Params.noindex }}
  {{- $priority := "0.5" }}
  {{- if .IsHome }}{{ $priority = "1.0" }}
  {{- else if and .IsPage (eq .Section "posts") }}{{ $priority = "0.9" }}
  {{- else if and .IsPage (eq .Section "events") }}{{ $priority = "0.7" }}
  {{- else if and .IsPage (eq .Section "authors") }}{{ $priority = "0.6" }}
  {{- else if not .IsPage }}
    {{- if eq .Section "posts" }}{{ $priority = "0.8" }}
    {{- else if eq .Section "tags" }}{{ $priority = "0.4" }}
    {{- else if eq .Section "authors" }}{{ $priority = "0.5" }}
    {{- else }}{{ $priority = "0.5" }}
    {{- end }}
  {{- end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
    {{- end }}
    <changefreq>{{ if .IsHome }}daily{{ else if and .IsPage (eq .Section "posts") }}monthly{{ else }}weekly{{ end }}</changefreq>
    <priority>{{ $priority }}</priority>
    {{- range .AllTranslations }}
    <xhtml:link rel="alternate" hreflang="{{ .Language.LanguageCode }}" href="{{ .Permalink }}" />
    {{- end }}
    {{- $xDefault := "" }}
    {{- range .AllTranslations }}{{ if eq .Language.Lang "en" }}{{ $xDefault = .Permalink }}{{ end }}{{ end }}
    {{- with $xDefault }}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ . }}" />
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
</urlset>
