&lt;td&gt;Layanan&lt;/td&gt;
&lt;td&gt;Percabangan&lt;/td&gt;
&lt;td&gt;Layanan&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Anthropic Claude, Ollama&lt;/td&gt;
&lt;td&gt;Klien&lt;/td&gt;
